# ============================================================
# MOCKINGBIRD — Central Configuration Reference
# ============================================================
#
# HOW TO USE
# ----------
# 1. Copy this file:
#      cp config/example.env config/local.env
#
# 2. Open config/local.env and fill in every value marked
#    CHANGE_THIS with your real organisation values.
#
# 3. local.env is gitignored — it will NEVER be committed.
#    Keep your real URLs and credentials only in that file.
#
# WHERE EACH VARIABLE IS CONSUMED
# --------------------------------
#
#   [COMPOSE]   docker-compose reads it via:
#               cd services && docker compose --env-file ../config/local.env up
#
#   [MAVEN]     settings.xml reads env vars natively: ${env.VARIABLE_NAME}
#               These are set automatically in GitLab CI pipeline environment.
#               For local Maven builds: export the vars before running mvn.
#
#   [GITLAB CI] These are NOT read from this file automatically by GitLab.
#               You must add them as CI/CD Variables in your GitLab project:
#               GitLab → Project → Settings → CI/CD → Variables → Add variable
#               Use this file as your reference for what to add.
#
#   [TERRAFORM] Source this file before running Terraform locally:
#               source config/local.env && terraform plan
#
# ============================================================


# ── ARTIFACTORY — Internal Package Mirror ────────────────────────────────────
# [MAVEN] [GITLAB CI] [COMPOSE build args]
#
# The single Maven virtual repository that proxies all external repos.
# Used in settings.xml and passed as a build arg to Dockerfiles.

ARTIFACTORY_MAVEN_URL=https://artifactory.internal/artifactory/dws-all-repos

# PyPI mirror — used as PIP_INDEX_URL build arg in Python service Dockerfiles
ARTIFACTORY_PYPI_URL=https://pypi.org/simple

# npm mirror — used as NPM_REGISTRY build arg in Node.js service Dockerfiles
ARTIFACTORY_NPM_URL=https://registry.npmjs.org

# Docker registry proxy — used as the base image source in all Dockerfiles
# This proxies Docker Hub, eclipse-temurin etc. through Artifactory
ARTIFACTORY_DOCKER_REGISTRY=docker.io

# Artifactory credentials — set automatically from Vault in GitLab CI.
# For local Maven builds only, set these manually.
ARTIFACTORY_USR=CHANGE_THIS
ARTIFACTORY_PSWD=CHANGE_THIS


# ── GITLAB — Container Registry & CI ─────────────────────────────────────────
# [GITLAB CI] [COMPOSE build args]
#
# Base URL of your GitLab Container Registry.
# GitLab CI already has $CI_REGISTRY_IMAGE built-in for the current project —
# use that for image names in pipelines. This variable is for cross-project refs.

GITLAB_REGISTRY=registry.gitlab.internal/CHANGE_THIS

# Fully qualified image path for the stub engine image
GITLAB_STUB_ENGINE_IMAGE=registry.gitlab.internal/CHANGE_THIS/mockingbird/stub-engine

# The Java 21 base image pulled from your GitLab registry (from Artifactory proxy)
# Used as ARG JAVA_BASE_IMAGE in stub engine Dockerfiles.
# Format: registry.gitlab.internal/<group>/executors/build/java/<image>:<tag>
JAVA_BASE_IMAGE=eclipse-temurin:21-jre-alpine

# Kaniko image — the container that builds Docker images in GitLab k8s runners
KANIKO_IMAGE_PATH=gcr.io/kaniko-project/executor:v1.24.0-debug

# GitLab runner tag for your shared Kubernetes runners
GITLAB_RUNNER_TAG=shared-runner


# ── VAULT — HashiCorp Vault (Phase 3+) ───────────────────────────────────────
# [GITLAB CI] [COMPOSE]
#
# The Vault server that holds all production secrets.
# In GitLab CI, secrets are fetched from Vault via JWT OIDC auth.

VAULT_SERVER_URL=https://vault.internal:8200
VAULT_NAMESPACE=secrets
VAULT_MOUNT_PATH=kv
VAULT_AUTH_ROLE=mockingbird
VAULT_AUTH_PATH=jwt/gitlab

# Path in Vault where Docker auth credentials are stored
VAULT_CI_DOCKER_SECRET_PATH=mockingbird/ci/docker

# Path in Vault where Artifactory credentials are stored
VAULT_CI_ARTIFACTORY_PATH=mockingbird/ci/artifactory


# ── PLATFORM DATABASE — PostgreSQL ───────────────────────────────────────────
# [COMPOSE]
#
# Used by auth-service and project-service to connect to PostgreSQL.
# In production (AWS ECS), these come from Vault — not from this file.

DB_PASSWORD=CHANGE_THIS_local_dev_password
DATABASE_URL=postgresql://mockingbird:CHANGE_THIS_local_dev_password@postgres:5432/mockingbird


# ── AUTH — JWT Secret ─────────────────────────────────────────────────────────
# [COMPOSE]
#
# MUST be the same value in both auth-service AND project-service.
# auth-service signs tokens with it; project-service verifies them.
#
# Generate a secure value:
#   python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET=CHANGE_THIS_generate_a_random_64_char_hex_string
JWT_ALGORITHM=HS256


# ── REDIS ─────────────────────────────────────────────────────────────────────
# [COMPOSE]

REDIS_URL=redis://redis:6379


# ── AWS ───────────────────────────────────────────────────────────────────────
# [COMPOSE] [TERRAFORM] [GITLAB CI]

AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=CHANGE_THIS
# Role that Mockingbird's deployer-worker assumes to provision EC2 instances (Phase 4)
AWS_DEPLOYER_ROLE_ARN=arn:aws:iam::CHANGE_THIS:role/MockingbirdDeployerRole

# S3 bucket for uploaded spec files and generated stub packages
# [COMPOSE] — read by ingestion-service (Sprint 10+) and worker services (Sprint 11+)
S3_BUCKET=mockingbird-stubs

# SQS queue URLs — [COMPOSE] — read by parser-worker and generator-worker (Sprint 11+)
# Format: https://sqs.{region}.amazonaws.com/{account_id}/{queue_name}
SQS_PARSE_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/CHANGE_THIS/mockingbird-parse-queue
SQS_GENERATE_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/CHANGE_THIS/mockingbird-generate-queue
SQS_DEPLOY_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/CHANGE_THIS/mockingbird-deploy-queue
SQS_REPORT_QUEUE_URL=https://sqs.eu-west-2.amazonaws.com/CHANGE_THIS/mockingbird-report-queue
SQS_DLQ_URL=https://sqs.eu-west-2.amazonaws.com/CHANGE_THIS/mockingbird-dlq


# ── LDAP (Phase 3 Sprint 12) ──────────────────────────────────────────────────
# [COMPOSE] — consumed by auth-service when LDAP is enabled

LDAP_SERVER=ldap://ldap.internal:389
LDAP_BASE_DN=DC=company,DC=com
LDAP_BIND_DN=CN=svc-mockingbird,OU=ServiceAccounts,DC=company,DC=com
LDAP_BIND_PASSWORD=CHANGE_THIS
LDAP_SV_TEAM_GROUP=CN=SV-Team,OU=Groups,DC=company,DC=com
LDAP_SV_USERS_GROUP=CN=SV-Users,OU=Groups,DC=company,DC=com


# ── MONITORING ────────────────────────────────────────────────────────────────
# [COMPOSE] [GITLAB CI]

SPLUNK_HEC_URL=https://splunk.internal:8088/services/collector
SPLUNK_HEC_TOKEN=CHANGE_THIS
APPDYNAMICS_CONTROLLER=https://appdynamics.internal
APPDYNAMICS_AGENT_KEY=CHANGE_THIS


# ── PLATFORM IDENTITY ─────────────────────────────────────────────────────────
# [COMPOSE]

PLATFORM_DOMAIN=mockingbird.internal
ENVIRONMENT=local


# ── DEPLOYER WORKER — GitLab CI + Terraform (Phase 4 Sprint 13) ──────────────
# [COMPOSE] — consumed by deployer-worker

# GitLab instance URL (same as your CI server)
GITLAB_URL=https://gitlab.internal

# Personal access token or deploy token with api + read_registry scope
# In production this comes from Vault — never commit a real token
GITLAB_TOKEN=CHANGE_THIS

# ID of the shared "stub-builder" GitLab project that Kaniko builds run in
# Find it: GitLab → Project → Settings → General → Project ID
GITLAB_STUB_BUILDER_PROJECT_ID=CHANGE_THIS

# Terraform remote state S3 bucket (must already exist + versioning enabled)
TERRAFORM_STATE_BUCKET=mockingbird-terraform-state

# DynamoDB table for Terraform state locking (must already exist, LockID pk)
TERRAFORM_LOCKS_TABLE=mockingbird-terraform-locks

# VPC subnet to launch stub EC2 instances into (private subnet with NAT preferred)
EC2_SUBNET_ID=subnet-CHANGE_THIS

# Security group that allows inbound TCP 8080 and outbound to GitLab registry
EC2_SECURITY_GROUP_ID=sg-CHANGE_THIS

# EC2 key pair name for break-glass SSH access (must exist in eu-west-2)
EC2_KEY_PAIR_NAME=mockingbird-key

# IAM instance profile attached to stub EC2 instances
# Must allow: ecr:GetAuthorizationToken, s3:GetObject (stubs bucket), secretsmanager:GetSecretValue
EC2_IAM_INSTANCE_PROFILE=MockingbirdStubInstanceProfile
