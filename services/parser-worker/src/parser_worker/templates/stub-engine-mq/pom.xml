<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>org.springframework.boot</groupId>
    <artifactId>spring-boot-starter-parent</artifactId>
    <version>3.3.0</version>
    <relativePath/>
  </parent>

  <!-- Filled in by generator-worker per project -->
  <groupId>com.mockingbird.stubs</groupId>
  <artifactId>{{project_id}}-stub</artifactId>
  <version>1.0.0</version>
  <name>{{project_name}} IBM MQ Stub Engine</name>
  <description>Mockingbird auto-generated IBM MQ stub for {{project_name}}</description>

  <properties>
    <java.version>21</java.version>
  </properties>

  <dependencies>
    <!-- Spring Boot lifecycle management, health checks, config -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter</artifactId>
    </dependency>

    <!-- Spring Web — for REST /api/stubs/{name}/trigger endpoint -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>

    <!--
      IBM MQ Spring Boot starter — auto-configures MQConnectionFactory,
      JmsTemplate, and DefaultJmsListenerContainerFactory from ibm.mq.* properties.
      Transitively brings in spring-jms and com.ibm.mq.allclient.
      All JARs resolved from Artifactory (configured in settings.xml).
    -->
    <dependency>
      <groupId>com.ibm.mq</groupId>
      <artifactId>mq-jms-spring-boot-starter</artifactId>
      <version>3.3.0</version>
    </dependency>

    <!-- Jackson — stubs.json deserialization -->
    <dependency>
      <groupId>com.fasterxml.jackson.core</groupId>
      <artifactId>jackson-databind</artifactId>
    </dependency>

    <!-- Prometheus metrics via /actuator/prometheus (scraped by platform) -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-actuator</artifactId>
    </dependency>
    <dependency>
      <groupId>io.micrometer</groupId>
      <artifactId>micrometer-registry-prometheus</artifactId>
      <scope>runtime</scope>
    </dependency>
  </dependencies>

  <build>
    <plugins>
      <plugin>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-maven-plugin</artifactId>
        <configuration>
          <mainClass>com.mockingbird.stubs.mq.MQStubApplication</mainClass>
        </configuration>
      </plugin>
    </plugins>
  </build>

  <!-- All JARs resolved from Artifactory (configured in settings.xml) -->

</project>
