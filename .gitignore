secrets.json
vault-token

# Terraform state (managed remotely via S3 + DynamoDB lock)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Generated stub projects (output of sv-gen)
stub-output/

# Node.js
node_modules/
npm-debug.log*
yarn-error.log*

# TypeScript build output
dist/
*.tsbuildinfo

# Java / Maven
target/
*.class
*.jar
