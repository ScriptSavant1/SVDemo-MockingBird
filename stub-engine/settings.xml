<?xml version="1.0" encoding="UTF-8"?>
<!-- Maven settings for Artifactory -->
<!-- Credentials come from ARTIFACTORY_USR / ARTIFACTORY_PSWD env vars (fetched from Vault in CI) -->
<settings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xmlns="http://maven.apache.org/SETTINGS/1.0.0"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0 http://maven.apache.org/xsd/settings-1.0.0.xsd">

  <localRepository>/tmp/maven-cache</localRepository>

  <servers>
    <server>
      <id>dws-all-fallback-zambezi-mirror</id>
      <username>${env.ARTIFACTORY_USR}</username>
      <password>${env.ARTIFACTORY_PSWD}</password>
    </server>
  </servers>

  <mirrors>
    <mirror>
      <id>dws-all-fallback-zambezi-mirror</id>
      <name>Artifactory (all repos)</name>
      <url>https://artifactory.internal/artifactory/dws-all-repos</url>
      <mirrorOf>*,!zambezi-all-repos</mirrorOf>
    </mirror>
  </mirrors>

  <profiles>
    <profile>
      <id>artifactory</id>
      <repositories>
        <repository>
          <id>dws-all-repos</id>
          <name>dws-all-repos</name>
          <url>https://artifactory.internal/artifactory/dws-all-repos</url>
          <layout>default</layout>
          <releases>
            <enabled>true</enabled>
            <updatePolicy>daily</updatePolicy>
            <checksumPolicy>fail</checksumPolicy>
          </releases>
          <snapshots>
            <enabled>true</enabled>
            <updatePolicy>always</updatePolicy>
            <checksumPolicy>fail</checksumPolicy>
          </snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>dws-all-repos</id>
          <name>dws-all-repos</name>
          <url>https://artifactory.internal/artifactory/dws-all-repos</url>
          <layout>default</layout>
          <releases>
            <enabled>true</enabled>
          </releases>
          <snapshots>
            <enabled>true</enabled>
          </snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>

  <activeProfiles>
    <activeProfile>artifactory</activeProfile>
  </activeProfiles>

</settings>
